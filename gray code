class Solution {
    public List<Integer> grayCode(int n) {
        List<Integer> result = new ArrayList<>();
        // Total numbers in a Gray code sequence for n bits is 2^n
        int numCount = 1 << n; 
        
        for (int i = 0; i < numCount; i++) {
            // Standard Binary to Gray conversion: i ^ (i / 2)
            result.add(i ^ (i >> 1));
        }
        
        return result;
    }
}
