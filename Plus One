class Solution {
    public int[] plusOne(int[] digits) {
        for (int i = digits.length - 1; i >= 0; i--) {
            // If the digit is less than 9, just add 1 and we're done
            if (digits[i] < 9) {
                digits[i]++;
                return digits;
            }
            
            // If it's 9, it becomes 0 and the loop carries over to the next digit
            digits[i] = 0;
        }

        // If the loop finished, it means the number was all 9s (e.g., 999 -> 1000)
        int[] result = new int[digits.length + 1];
        result[0] = 1; 
        // Remaining elements are already 0 by default in Java arrays
        return result;
    }
}
