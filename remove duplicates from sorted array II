class Solution {
    public int removeDuplicates(int[] nums) {
        // If the array has 2 or fewer elements, it already meets the criteria
        if (nums.length <= 2) {
            return nums.length;
        }

        // Pointer for the position where the next valid element should be placed
        // We start at index 2 because the first two elements are always kept
        int k = 2;

        // Iterate through the array starting from the third element
        for (int i = 2; i < nums.length; i++) {
            // Compare the current element with the element two positions behind 'k'
            // If they are different, it means we haven't kept 2 of this value yet
            if (nums[i] != nums[k - 2]) {
                nums[k] = nums[i];
                k++;
            }
        }

        // 'k' represents the number of elements meeting the criteria
        return k;
    }
}
