import java.util.*;

class Solution {
    public String simplifyPath(String path) {
        Deque<String> stack = new LinkedList<>();
        // Split by one or more slashes
        String[] components = path.split("/");

        for (String directory : components) {
            if (directory.equals("..")) {
                // Go up one level: pop from stack if not empty
                if (!stack.isEmpty()) {
                    stack.pop();
                }
            } else if (!directory.isEmpty() && !directory.equals(".")) {
                // Valid directory name: push to stack
                stack.push(directory);
            }
            // Ignore empty strings (from "//") and "."
        }

        // Build the result from the bottom of the stack
        StringBuilder result = new StringBuilder();
        if (stack.isEmpty()) return "/";
        
        while (!stack.isEmpty()) {
            result.append("/").append(stack.pollLast());
        }

        return result.toString();
    }
}
