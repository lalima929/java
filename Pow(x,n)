class Solution {
    public double myPow(double x, double n) {
        // Explicitly cast double to long to fix "lossy conversion" error
        long N = (long) n; 
        
        if (N < 0) {
            x = 1 / x;
            N = -N;
        }
        
        double result = 1;
        double currentProduct = x;
        
        while (N > 0) {
            if (N % 2 == 1) {
                result *= currentProduct;
            }
            currentProduct *= currentProduct;
            N /= 2;
        }
        
        return result;
    }
}
